{
    "mcpServers": {
        "nix-online": {
            "command": "systemd-run",
            "args": [
                "--scope",
                "--user",
                "-p",
                "MemoryMax=1G",
                "-p",
                "MemorySwapMax=2G",
                "mcp-nixos"
            ]
        }
    }
}
