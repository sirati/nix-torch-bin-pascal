{
    "mcpServers": {
        "language-nil": {
            "command": "systemd-run",
            "args": [
                "--scope",
                "--user",
                "-p",
                "MemoryMax=1G",
                "-p",
                "MemorySwapMax=2G",
                "mcp-language-server",
                "--workspace",
                "./",
                "--lsp",
                "nil",
                "--",
                "--stdio"
            ]
        },
        "language-nixd": {
            "command": "systemd-run",
